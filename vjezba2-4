<?php
$naslov = "Izračun varijable c";
$ime    = "Matija Mauzer";
 
$a = $b = $c = null;
$prikaziRezultat = false;
 
if (isset($_GET['a']) && isset($_GET['b']) && $_GET['a'] !== '' && $_GET['b'] !== '') {
    $a = (float)$_GET['a'];
    $b = (float)$_GET['b'];
    $c = (3 * $a - $b) / 2;
    $prikaziRezultat = true;
}
?>
