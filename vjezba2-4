    <p>Formula: <strong>c = (3a – b) / 2</strong></p>
 
    <form method="GET" action="formula.php">
      <label>Vrijednost a: <input type="text" name="a" value="<?php echo isset($_GET['a']) ? htmlspecialchars($_GET['a']) : ''; ?>"></label>
      <label>Vrijednost b: <input type="text" name="b" value="<?php echo isset($_GET['b']) ? htmlspecialchars($_GET['b']) : ''; ?>"></label>
      <button type="submit" class="gumb">Pošalji</button>
    </form>
 
    <?php if ($prikaziRezultat): ?>
      <div class="rezultat">
        c = (3 × <?php echo $a; ?> – <?php echo $b; ?>) / 2 = <strong><?php echo $c; ?></strong>
      </div>
    <?php endif; ?>
