<?php
$naslov = "PHP dokument — vježba 1d";
$ime    = "Matija Mauzer";
$opis   = "Ova stranica nastavlja vježbu 1c i prikazuje formu s izborom teme i slike.";

$tema       = isset($_GET['tema'])  ? $_GET['tema']  : 'dark';
$slikaKey   = isset($_GET['slika']) ? $_GET['slika'] : 'php';
$prikaziOpis = isset($_GET['opis']);

$teme   = ['dark', 'light'];
$slike  = ['php' => 'img/wrc.jpeg', 'server' => 'img/f1.jpg', 'code' => 'img/code.jpg'];

if (!in_array($tema, $teme))       $tema     = 'dark';
if (!array_key_exists($slikaKey, $slike)) $slikaKey = 'php';

$slikaPath = $slike[$slikaKey];

if ($tema === 'dark') {
    $bgBoja    = '#0f172a';
    $blokBoja  = '#ffffff';
    $textBoja  = '#111827';
} else {
    $bgBoja    = '#f1f5f9';
    $blokBoja  = '#ffffff';
    $textBoja  = '#111827';
}
?>
